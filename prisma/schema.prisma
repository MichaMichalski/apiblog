generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./data/blog.db"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  posts        Post[]
}

model Post {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  content        String    @default("[]")
  excerpt        String    @default("")
  status         String    @default("draft")
  featuredImage  String?
  seoTitle       String?
  seoDescription String?
  focusKeyword   String?
  noIndex        Boolean   @default(false)
  canonicalUrl   String?
  authorId       String
  author         User      @relation(fields: [authorId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  publishedAt    DateTime?
}

model Page {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  content        String   @default("[]")
  status         String   @default("draft")
  seoTitle       String?
  seoDescription String?
  focusKeyword   String?
  noIndex        Boolean  @default(false)
  canonicalUrl   String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Media {
  id        String   @id @default(cuid())
  filename  String
  path      String
  mimeType  String
  size      Int
  width     Int      @default(0)
  height    Int      @default(0)
  alt       String   @default("")
  createdAt DateTime @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Redirect {
  id          String   @id @default(cuid())
  source      String   @unique
  destination String
  statusCode  Int      @default(301)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
