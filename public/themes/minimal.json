{
  "version": "2.0",
  "colors": {
    "primary": "#000000",
    "primaryHover": "#333333",
    "secondary": "#666666",
    "secondaryHover": "#444444",
    "background": "#FFFFFF",
    "surface": "#FAFAFA",
    "surfaceHover": "#F5F5F5",
    "text": "#111111",
    "textMuted": "#888888",
    "border": "#EEEEEE",
    "error": "#CC0000",
    "success": "#008800",
    "warning": "#CC8800"
  },
  "fonts": {
    "heading": { "family": "Georgia, serif", "weight": "400" },
    "body": { "family": "system-ui, sans-serif", "weight": "400" }
  },
  "layout": {
    "maxWidth": "960px",
    "contentWidth": "680px",
    "sidebarPosition": "right",
    "headerStyle": "static"
  },
  "components": {
    "card": { "borderRadius": "0px", "shadow": "none" },
    "button": { "borderRadius": "0px" },
    "input": { "borderRadius": "0px" }
  },
  "spacing": {
    "sectionGap": "2.5rem",
    "paragraphGap": "1.25rem",
    "cardGap": "1.25rem"
  },
  "elements": {
    "body": { "fontSize": "16px", "lineHeight": "1.7", "letterSpacing": "0" },
    "h1": { "fontSize": "2rem", "lineHeight": "1.3", "letterSpacing": "0", "marginBottom": "1rem", "color": "", "textTransform": "none" },
    "h2": { "fontSize": "1.5rem", "lineHeight": "1.35", "letterSpacing": "0", "marginBottom": "0.75rem", "color": "", "textTransform": "none" },
    "h3": { "fontSize": "1.25rem", "lineHeight": "1.4", "letterSpacing": "0", "marginBottom": "0.75rem", "color": "", "textTransform": "none" },
    "h4": { "fontSize": "1.125rem", "lineHeight": "1.4", "letterSpacing": "0", "marginBottom": "0.5rem", "color": "", "textTransform": "none" },
    "h5": { "fontSize": "1rem", "lineHeight": "1.5", "letterSpacing": "0", "marginBottom": "0.5rem", "color": "", "textTransform": "none" },
    "h6": { "fontSize": "0.875rem", "lineHeight": "1.5", "letterSpacing": "0.05em", "marginBottom": "0.5rem", "color": "#888888", "textTransform": "uppercase" },
    "paragraph": { "fontSize": "1rem", "lineHeight": "1.8", "marginBottom": "1.25rem", "color": "" },
    "link": { "color": "", "hoverColor": "", "underline": "always", "fontWeight": "inherit" },
    "blockquote": { "borderLeftWidth": "2px", "borderLeftColor": "#CCCCCC", "backgroundColor": "", "padding": "0.5rem 1rem", "fontStyle": "italic", "fontSize": "1rem", "color": "#666666" },
    "image": { "borderRadius": "0", "shadow": "none", "margin": "1.5rem 0" },
    "code": { "fontFamily": "monospace", "fontSize": "0.875em", "backgroundColor": "#F5F5F5", "padding": "0.125rem 0.375rem", "borderRadius": "0", "color": "" },
    "codeBlock": { "backgroundColor": "#FAFAFA", "borderColor": "#EEEEEE", "borderRadius": "0", "padding": "1rem", "fontSize": "0.875rem", "lineHeight": "1.6" },
    "list": { "paddingLeft": "1.25rem", "itemSpacing": "0.375rem", "markerColor": "#888888" },
    "hr": { "borderColor": "#EEEEEE", "borderWidth": "1px", "margin": "2.5rem 0" },
    "table": { "borderColor": "#EEEEEE", "headerBackground": "", "headerColor": "#888888", "stripedRows": "false", "fontSize": "0.875rem" }
  },
  "sections": {
    "header": { "height": "56px", "background": "", "borderColor": "#EEEEEE", "shadow": "none", "logoFontSize": "1.125rem", "navFontSize": "0.875rem", "navGap": "1.5rem", "padding": "0 1.5rem", "sticky": "false" },
    "footer": { "background": "", "textColor": "#888888", "borderColor": "#EEEEEE", "padding": "1.5rem 0", "fontSize": "0.8125rem" },
    "hero": { "background": "", "textColor": "", "padding": "3rem 1.5rem", "titleFontSize": "2rem", "descriptionFontSize": "1rem", "textAlign": "center", "backgroundImage": "", "backgroundSize": "cover", "backgroundPosition": "center", "overlay": "" },
    "postCard": { "background": "", "borderColor": "#EEEEEE", "borderRadius": "0", "shadow": "none", "hoverShadow": "none", "imageAspectRatio": "16/9", "titleFontSize": "1.125rem", "excerptFontSize": "0.875rem", "metaFontSize": "0.75rem", "padding": "1rem" },
    "content": { "maxWidth": "680px", "padding": "0 1.5rem", "imageMaxWidth": "100%", "imageAlignment": "center" }
  },
  "backgrounds": {
    "body": { "type": "solid", "color": "", "image": "", "size": "cover", "position": "center", "repeat": "no-repeat", "attachment": "scroll" }
  },
  "effects": {
    "shadows": { "sm": "none", "md": "none", "lg": "none", "xl": "none" },
    "transitions": { "duration": "0.1s", "timing": "ease" },
    "borderRadius": { "sm": "0px", "md": "0px", "lg": "0px", "full": "9999px" }
  }
}
